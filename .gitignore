# my-web-2025 .gitignore — cleaned and organized
# See https://help.github.com/articles/ignoring-files/ for details

# Node / dependencies
/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Bun / caches
/.bun/
/.cache/bun/

# Build outputs
/.next/
/out/
/build/
/dist/
/.next-build-id
/.swc/

# Turbopack / cache
/.turbo/

# Framework / hosting
.vercel/
.vercel_build_output/

# Coverage and test artifacts
/coverage/
coverage-*.json
.jest-cache/
.jest-cache-coverage/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Environment files (keep example files if present)
.env*
!.env.example

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Temporary / misc
*.pem
test-api-debug.js
missing-images-report.json
cache-bust-config.json

# Data generator outputs (keep these ignored)
data/tag-catalog.json

# Lighthouse audit results
lighthouse-results/

# Rust build artifacts
apps/cms-api/target/*
apps/cms-api/.cargo/
apps/cms-api/Cargo.lock

# Subtree lockfiles - prevent Turbopack from detecting wrong workspace root
src/app/tools/*/pnpm-lock.yaml

# WSLc / Docker overrides
docker-compose.override.yml
