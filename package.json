{
	"name": "my-web-2025",
	"version": "2.1.1",
	"private": true,
	"sideEffects": [
		"node_modules/gsap/**",
		"node_modules/@gsap/**"
	],
	"packageManager": "bun@1.3.10",
	"scripts": {
		"dev": "bun --bun next dev -p 3010",
		"dev:cms-api": "bun ./scripts/dev-cms-api.ts",
		"dev:full": "bun ./scripts/dev-with-cms.ts",
		"sync:cms-entries": "bun ./scripts/sync-legacy-contents-to-rust.ts",
		"sync:cms-markdown": "bun ./scripts/sync-legacy-markdown-to-rust.ts",
		"sync:cms-media": "bun ./scripts/sync-legacy-media-to-rust.ts",
		"build": "bun scripts/check-env.js && bun x next build && bun scripts/copy-content-data.js",
		"start": "bun --bun next start -p 3010",
		"dev:port": "bun x next dev -p $PORT",
		"start:port": "bun --bun next start -p $PORT",
		"type-check": "tsc --noEmit",
		"test": "bun test",
		"lint": "biome check .",
		"format": "biome format --write .",
		"migration:add-indexes": "bun src/cms/lib/migrations/add-indexes.ts",
		"wslc:pull": "wslc pull oven/bun:1.3.10-debian",
		"wslc:run": "wslc run -d --name my-web-2025-dev -p 3010:3010 -v .:/workspace -v my-web-2025-node_modules:/workspace/node_modules -w /workspace oven/bun:1.3.10-debian sh -lc \"bun install --frozen-lockfile && bun --bun next dev -p 3010\"",
		"wslc:logs": "wslc logs my-web-2025-dev",
		"wslc:stop": "wslc stop my-web-2025-dev",
		"wslc:remove": "wslc remove my-web-2025-dev"
	},
	"trustedDependencies": [
		"sharp",
		"msw",
		"unrs-resolver"
	],
	"pnpm": {
		"peerDependencyRules": {
			"allowedVersions": {
				"three": "^0.180.0 || ^0.181.0"
			},
			"ignoreMissing": []
		},
		"ignoredBuiltDependencies": []
	},
	"dependencies": {
		"@appletosolutions/reactbits": "^1.0.3",
		"@chakra-ui/react": "^3.28.0",
		"@emotion/react": "^11.14.0",
		"@ffmpeg/ffmpeg": "^0.12.15",
		"@ffmpeg/util": "^0.12.2",
		"@hello-pangea/dnd": "^18.0.1",
		"@mui/icons-material": "^9.0.1",
		"@mui/material": "^9.0.1",
		"@radix-ui/react-slot": "^1.2.3",
		"@use-gesture/react": "^10.3.1",
		"animejs": "^4.4.1",
		"autoprefixer": "^10.4.21",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"dompurify": "^3.3.0",
		"framer-motion": "^12.23.24",
		"fuse.js": "^7.1.0",
		"gsap": "^3.13.0",
		"isomorphic-dompurify": "^3.14.0",
		"js-tiktoken": "^1.0.21",
		"jszip": "^3.10.1",
		"lucide-react": "^1.16.0",
		"marked": "^18.0.4",
		"motion": "^12.23.12",
		"nanoid": "^5.1.6",
		"next": "^16.2.6",
		"p5": "^2.1.1",
		"pixi-filters": "^6.1.4",
		"pixi.js": "^8.14.0",
		"prismjs": "^1.30.0",
		"qrcode": "^1.5.4",
		"qrcode.react": "^4.2.0",
		"react": "^19.2.1",
		"react-dom": "^19.2.1",
		"react-dropzone": "^14.3.8",
		"recharts": "^3.3.0",
		"resend": "^6.3.0",
		"sharp": "^0.34.4",
		"tailwind-merge": "^3.3.1",
		"tailwindcss": "^4.1.16",
		"three": "^0.180.0",
		"web-vitals": "^5.1.0",
		"zod": "^4.1.12"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.2",
		"@jest/globals": "^30.2.0",
		"@tailwindcss/postcss": "^4.1.16",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.0",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.9.1",
		"@types/p5": "^1.7.7",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@types/three": "^0.180.0",
		"@types/youtube": "^0.1.2",
		"baseline-browser-mapping": "^2.9.19",
		"chrome-launcher": "^1.2.1",
		"jest": "^30.2.0",
		"jest-environment-jsdom": "^30.2.0",
		"jsdom": "^27.0.1",
		"lighthouse": "^13.0.1",
		"playwright": "^1.48.0",
		"tsx": "^4.20.6",
		"typescript": "5.9.3"
	},
	"overrides": {
		"three": "^0.180.0",
		"baseline-browser-mapping": "^2.8.32"
	}
}
